# ─────────────────────────────────────────────────────────────────
# Food Delivery Scraper — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Arch Linux: point Playwright to system Chromium (installed via pacman)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium

# Logging
SCRAPER_LOG_LEVEL=INFO

# Browser
SCRAPER_BROWSER_HEADLESS=true
SCRAPER_BROWSER_TIMEOUT_MS=30000

# Proxy (comma-separated list, or leave blank to disable)
SCRAPER_PROXY_ENABLED=false
SCRAPER_PROXY_PROXIES=
SCRAPER_PROXY_MAX_FAILURES=3
SCRAPER_PROXY_ROTATION_STRATEGY=least_failed

# Storage
SCRAPER_STORAGE_BACKEND=sqlite
# SCRAPER_STORAGE_POSTGRES_DSN=postgresql://user:pass@localhost:5432/food_scraper

# Rate limiting (milliseconds)
SCRAPER_RATE_MIN_DELAY_MS=1500
SCRAPER_RATE_MAX_DELAY_MS=4000
SCRAPER_RATE_PAGE_DELAY_MS=3000
